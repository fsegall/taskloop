# ──────────────────────────────────────────────
# Stellar Testnet — payout principal
# ──────────────────────────────────────────────
# Conta-fonte que assina e envia pagamentos.
# Sem essas chaves, o sistema usa payout mockado.
# Para criar e fundar uma conta testnet: https://friendbot.stellar.org
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOURCE_PUBLIC=
STELLAR_SOURCE_SECRET=
STELLAR_USE_MOCK=false

# ──────────────────────────────────────────────
# x402 — cliente pagador para demo E2E
# ──────────────────────────────────────────────
# Conta separada que age como "cliente" pagando pelo recurso premium.
# Usada pelos scripts demo:x402 e demo:x402:e2e.
X402_CLIENT_PUBLIC=
X402_CLIENT_SECRET=
X402_PRICE_XLM=0.1
X402_RECEIVER_PUBLIC=
X402_MEMO_PREFIX=taskloop-x402

# ──────────────────────────────────────────────
# Etherfuse / Anchor
# ──────────────────────────────────────────────
# Sem API key, o adapter usa mock automaticamente.
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_USE_MOCK=false
ETHERFUSE_API_KEY=

# Wallet Etherfuse (se gerada no onboarding)
ETHERFUSE_PUBLIC_KEY=
ETHERFUSE_SECRET_KEY=

# ──────────────────────────────────────────────
# Telegram — bot via BotFather (próximas sprints)
# ──────────────────────────────────────────────
# Na Sprint 2 o adapter é mockado.
# Para modo real, registrar bot em https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# Agentes — webhooks opcionais
# ──────────────────────────────────────────────
# Sem webhook, os agentes usam fallback local.
TASK_AGENT_WEBHOOK_URL=
VALIDATION_AGENT_WEBHOOK_URL=

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
PORT=3000