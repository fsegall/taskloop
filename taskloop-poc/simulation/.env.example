# Deepseek API Key (https://platform.deepseek.com) — opcional, usa logos demo se ausente
DEEPSEEK_API_KEY=sk-sua-chave-aqui

# Porta do servidor
PORT=3001

# Stellar Treasury — secret key da wallet que envia os pagamentos
# Deve estar financiada na Mainnet com XLM suficiente (5+ XLM para demo)
STELLAR_SECRET_KEY=SXXXsua-secret-key-aqui

# Valor em XLM enviado a cada votante (padrão: 0.5 XLM ≈ R$1)
STELLAR_PAYMENT_AMOUNT=0.5

# Máximo de votos/pagamentos por sessão de votação (proteção contra abuso)
MAX_VOTES_PER_SESSION=10

# Reserva mínima em XLM que a treasury deve manter após cada pagamento
TREASURY_MIN_RESERVE=2

# Senha para iniciar a votação (apenas o organizador consegue gerar logos e abrir pagamentos)
ORGANIZER_PASSWORD=minha-senha-secreta
